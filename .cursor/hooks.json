{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/repo-policy.py",
        "matcher": "Shell|Write|StrReplace|Delete"
      }
    ],
    "beforeReadFile": [
      {
        "command": "python3 .cursor/hooks/repo-policy.py",
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": "python3 .cursor/hooks/repo-policy.py"
      }
    ]
  }
}
